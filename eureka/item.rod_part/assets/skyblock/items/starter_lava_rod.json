{
  "model": {
    "type": "condition",
    "property": "minecraft:fishing_rod/cast",
    "on_false": {
      "type": "composite",
      "models": [
        {
          "type": "model",
          "model": "eureka:item/starter_lava_rod"
        },
        {
          "type": "condition",
          "property": "catharsis:is_data_type_present",
          "data_type": "line",
          "on_true": {
            "type": "select",
            "property": "catharsis:data_type",
            "data_type": "line",
            "cases": [
              {
                "when": "titan_line",
                "model": {
                  "type": "model",
                  "model": "eureka:item/titan_line"
                }
              },
              {
                "when": "speedy_line",
                "model": {
                  "type": "model",
                  "model": "eureka:item/speedy_line"
                }
              },
              {
                "when": "shredded_line",
                "model": {
                  "type": "model",
                  "model": "eureka:item/shredded_line"
                }
              }
            ],
            "fallback": {
              "type": "model",
              "model": "eureka:item/default_line"
            }
          },
          "on_false": {
            "type": "model",
            "model": "eureka:item/default_line"
          }
        },
        {
          "type": "condition",
          "property": "catharsis:is_data_type_present",
          "data_type": "sinker",
          "on_true": {
            "type": "select",
            "property": "catharsis:data_type",
            "data_type": "sinker",
            "cases": [
              {
                "when": "junk_sinker",
                "model": {
                  "type": "model",
                  "model": "eureka:item/junk_sinker"
                }
              },
              {
                "when": "prismarine_sinker",
                "model": {
                  "type": "model",
                  "model": "eureka:item/prismarine_sinker"
                }
              },
              {
                "when": "icy_sinker",
                "model": {
                  "type": "model",
                  "model": "eureka:item/icy_sinker"
                }
              },
              {
                "when": "festive_sinker",
                "model": {
                  "type": "model",
                  "model": "eureka:item/festive_sinker"
                }
              },
              {
                "when": "sponge_sinker",
                "model": {
                  "type": "model",
                  "model": "eureka:item/sponge_sinker"
                }
              },
              {
                "when": "stingy_sinker",
                "model": {
                  "type": "model",
                  "model": "eureka:item/stingy_sinker"
                }
              },
              {
                "when": "hotspot_sinker",
                "model": {
                  "type": "model",
                  "model": "eureka:item/hotspot_sinker"
                }
              },
              {
                "when": "chum_sinker",
                "model": {
                  "type": "model",
                  "model": "eureka:item/chum_sinker"
                }
              }
            ],
            "fallback": {
              "type": "minecraft:empty"
            }
          },
          "on_false": {
            "type": "minecraft:empty"
          }
        },
        {
          "type": "condition",
          "property": "catharsis:is_data_type_present",
          "data_type": "hook",
          "on_true": {
            "type": "select",
            "property": "catharsis:data_type",
            "data_type": "hook",
            "cases": [
              {
                "when": "treasure_hook",
                "model": {
                  "type": "model",
                  "model": "eureka:item/treasure_hook"
                }
              },
              {
                "when": "phantom_hook",
                "model": {
                  "type": "model",
                  "model": "eureka:item/phantom_hook"
                }
              },
              {
                "when": "common_hook",
                "model": {
                  "type": "model",
                  "model": "eureka:item/common_hook"
                }
              },
              {
                "when": "hotspot_hook",
                "model": {
                  "type": "model",
                  "model": "eureka:item/hotspot_hook"
                }
              }
            ],
            "fallback": {
              "type": "model",
              "model": "eureka:item/default_hook"
            }
          },
          "on_false": {
            "type": "model",
            "model": "eureka:item/default_hook"
          }
        }
      ]
    },
    "on_true": { "type": "model", "model": "eureka:item/starter_lava_rod" }
  }
}
